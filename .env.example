# ============================================================
# PermitFlow ES — Variables de entorno
# Copiar este archivo a .env.local (frontend) y .env (api)
# NUNCA commitear archivos con valores reales
# ============================================================

# --- FRONTEND (apps/web/.env.local) -------------------------

# Clerk — autenticación
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URL del backend local
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe — pagos (clave pública para el frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PostHog — analytics de producto
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com


# --- BACKEND (apps/api/.env) --------------------------------

# Base de datos — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis — caché
REDIS_URL=redis://localhost:6379

# Clerk — verificación de tokens en el backend
CLERK_SECRET_KEY=sk_test_...

# Anthropic — Claude API para motor normativo e IA
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — pagos y webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — emails transaccionales
RESEND_API_KEY=re_...

# Supabase — storage de documentos PDF
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry — monitoreo de errores
SENTRY_DSN=https://...@sentry.io/...

# Entorno
ENVIRONMENT=development

# Notificaciones
NOTIFICATION_EMAIL=tu@email.com
RESEND_FROM_DOMAIN=tu-dominio.com
