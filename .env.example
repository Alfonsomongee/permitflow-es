# ============================================================
# PermitFlow ES - environment variables
# Copy the frontend block to apps/web/.env.local.
# Copy the backend block to apps/api/.env.
# Never commit real secrets.
# ============================================================

# --- FRONTEND (apps/web/.env.local) -------------------------

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# URLs
NEXT_PUBLIC_URL=http://localhost:3007
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Google Maps Places autocomplete
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# DeepSeek chat proxy. Server-side only, never NEXT_PUBLIC.
DEEPSEEK_API_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com


# --- BACKEND (apps/api/.env) --------------------------------

# Database - Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Redis cache
REDIS_URL=redis://localhost:6379

# AI provider
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Google Geocoding API
GOOGLE_MAPS_API_KEY=

# Clerk token verification
CLERK_SECRET_KEY=sk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=tu@email.com
RESEND_FROM_DOMAIN=tu-dominio.com

# Supabase service integrations
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Monitoring
SENTRY_DSN=https://...@sentry.io/...

# Runtime
ENVIRONMENT=development
