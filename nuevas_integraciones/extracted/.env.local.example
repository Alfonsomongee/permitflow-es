# ============================================================
# apps/web/.env.local
# ============================================================
# Copia este archivo como .env.local y rellena todos los valores.
# NUNCA subas .env.local a git (ya está en .gitignore).

# ─── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3007

# ─── Backend FastAPI ──────────────────────────────────────────
# En desarrollo: http://localhost:8000
# En producción: URL de tu servidor / Railway / Fly.io
API_URL=http://localhost:8000

# ─── Clerk ───────────────────────────────────────────────────
# Obtén estas claves en: https://dashboard.clerk.com
# → Tu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas de Clerk (no cambiar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/expedientes
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/expedientes

# Webhook secret para sincronizar organizaciones con Supabase
# Obtén en: Clerk Dashboard → Webhooks → tu endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ────────────────────────────────────────────────
# Obtén en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
# SERVICE_ROLE: solo server-side, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ─── Stripe ──────────────────────────────────────────────────
# Obtén en: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret: Stripe Dashboard → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs de Stripe (crear producto "PermitFlow Pro" en Stripe Dashboard)
# → Products → Add product → Add price (recurring, monthly, 49€)
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Places (formulario de municipio) ─────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── DeepSeek (proxy server-side) ────────────────────────────
# NUNCA usar NEXT_PUBLIC_ — solo accesible desde el servidor
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
