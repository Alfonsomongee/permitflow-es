{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema de reglas normativas — PermitFlow ES",
  "type": "object",
  "required": ["tipo_instalacion", "comunidad", "version", "ultima_revision", "fuentes", "reglas"],
  "properties": {
    "tipo_instalacion": {
      "type": "string",
      "enum": [
        "fotovoltaica_autoconsumo",
        "fotovoltaica_vertido_red",
        "eolica_pequeña",
        "climatizacion_aerotermia",
        "climatizacion_split",
        "climatizacion_vrf",
        "climatizacion_industrial",
        "acs_solar_termica",
        "acs_bomba_calor",
        "gas_baja_presion",
        "gas_media_presion",
        "baja_tension_industria",
        "baja_tension_residencial",
        "media_tension"
      ]
    },
    "comunidad": {
      "type": "string",
      "enum": [
        "andalucia", "aragon", "asturias", "baleares", "canarias",
        "cantabria", "castilla_la_mancha", "castilla_leon", "cataluna",
        "ceuta", "comunidad_valenciana", "extremadura", "galicia",
        "la_rioja", "madrid", "melilla", "murcia", "navarra", "pais_vasco"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "ultima_revision": {
      "type": "string",
      "format": "date"
    },
    "revisado_por": {
      "type": "string"
    },
    "fuentes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "reglas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "descripcion", "condicion", "tramites"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]{2,4}-[A-Z]{2,4}-\\d{3}$"
          },
          "descripcion": { "type": "string" },
          "condicion": { "type": ["object", "boolean"] },
          "tramites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["orden", "nombre", "organismo", "base_legal", "plazo_estimado_dias", "documentos_requeridos"],
              "properties": {
                "orden": { "type": "integer", "minimum": 1 },
                "nombre": { "type": "string" },
                "organismo": { "type": "string" },
                "base_legal": { "type": "string" },
                "plazo_estimado_dias": { "type": "integer", "minimum": 0 },
                "plazo_legal_dias": { "type": ["integer", "null"] },
                "documentos_requeridos": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "formulario_ref": { "type": ["string", "null"] },
                "paralelo_con": {
                  "type": ["array", "null"],
                  "items": { "type": "string" }
                },
                "notas": { "type": "string" },
                "obsoleta": { "type": "boolean", "default": false },
                "obsoleta_desde": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    }
  }
}
